{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "prefix": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30,
            "metadata": {
                "description": "Base name for all resources. Will create <prefix>, <prefix>-is, <prefix>-wh, <prefix>-rc, <prefix>-asp, <prefix>db."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "East US",
            "metadata": {
                "description": "Region for the App Service Plan and all Web Apps."
            }
        },
        "sqlServerName": {
            "type": "string",
            "defaultValue": "dovorch22sql-dwhngduyobf2g",
            "metadata": {
                "description": "Name of the EXISTING SQL server that will host the new database."
            }
        },
        "sqlDatabaseLocation": {
            "type": "string",
            "defaultValue": "East US",
            "metadata": {
                "description": "Must match the region of the existing SQL server."
            }
        }
    },
    "variables": {
        "appServicePlanName": "[concat(parameters('prefix'), '-asp')]",
        "siteNames": [
            "[parameters('prefix')]",
            "[concat(parameters('prefix'), '-is')]",
            "[concat(parameters('prefix'), '-wh')]",
            "[concat(parameters('prefix'), '-rc')]"
        ],
        "sqlDatabaseName": "[concat(parameters('prefix'), 'db')]",
        "commonTags": {
            "Owner": "Dov.Banach@uipath.com",
            "Project": "Infrastructure"
        }
    },
    "resources": [
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2024-11-01",
            "name": "[variables('appServicePlanName')]",
            "location": "[parameters('location')]",
            "kind": "app",
            "sku": {
                "name": "S1",
                "tier": "Standard",
                "size": "S1",
                "family": "S",
                "capacity": 1
            },
            "properties": {
                "reserved": false
            },
            "tags": "[variables('commonTags')]"
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2024-11-01",
            "name": "[variables('siteNames')[copyIndex()]]",
            "location": "[parameters('location')]",
            "kind": "app",
            "copy": {
                "name": "sitesCopy",
                "count": "[length(variables('siteNames'))]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
            ],
            "properties": {
                "clientAffinityEnabled": true,
                "clientAffinityProxyEnabled": false,
                "clientCertEnabled": false,
                "clientCertMode": "Required",
                "containerSize": 0,
                "dailyMemoryTimeQuota": 0,
                "dnsConfiguration": {},
                "enabled": true,
                "endToEndEncryptionEnabled": false,
                "hostNameSslStates": [
                    {
                        "hostType": "Standard",
                        "name": "[concat(variables('siteNames')[copyIndex()], '.azurewebsites.net')]",
                        "sslState": "Disabled"
                    },
                    {
                        "hostType": "Repository",
                        "name": "[concat(variables('siteNames')[copyIndex()], '.scm.azurewebsites.net')]",
                        "sslState": "Disabled"
                    }
                ],
                "hostNamesDisabled": false,
                "httpsOnly": true,
                "hyperV": false,
                "ipMode": "IPv4",
                "isXenon": false,
                "keyVaultReferenceIdentity": "SystemAssigned",
                "outboundVnetRouting": {
                    "allTraffic": false,
                    "applicationTraffic": false,
                    "backupRestoreTraffic": false,
                    "contentShareTraffic": false,
                    "imagePullTraffic": false
                },
                "publicNetworkAccess": "Enabled",
                "redundancyMode": "None",
                "reserved": false,
                "scmSiteAlsoStopped": false,
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
                "siteConfig": {
                    "acrUseManagedIdentityCreds": false,
                    "alwaysOn": true,
                    "functionAppScaleLimit": 0,
                    "http20Enabled": false,
                    "minimumElasticInstanceCount": 1,
                    "numberOfWorkers": 1
                },
                "storageAccountRequired": false
            },
            "tags": "[variables('commonTags')]"
        },
        {
            "type": "Microsoft.Web/sites/basicPublishingCredentialsPolicies",
            "apiVersion": "2024-11-01",
            "name": "[concat(variables('siteNames')[copyIndex()], '/ftp')]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "ftpPolicyCopy",
                "count": "[length(variables('siteNames'))]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('siteNames')[copyIndex()])]"
            ],
            "properties": {
                "allow": true
            },
            "tags": "[variables('commonTags')]"
        },
        {
            "type": "Microsoft.Web/sites/basicPublishingCredentialsPolicies",
            "apiVersion": "2024-11-01",
            "name": "[concat(variables('siteNames')[copyIndex()], '/scm')]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "scmPolicyCopy",
                "count": "[length(variables('siteNames'))]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('siteNames')[copyIndex()])]"
            ],
            "properties": {
                "allow": true
            },
            "tags": "[variables('commonTags')]"
        },
        {
            "type": "Microsoft.Web/sites/config",
            "apiVersion": "2024-11-01",
            "name": "[concat(variables('siteNames')[copyIndex()], '/web')]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "siteConfigCopy",
                "count": "[length(variables('siteNames'))]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('siteNames')[copyIndex()])]"
            ],
            "properties": {
                "acrUseManagedIdentityCreds": false,
                "alwaysOn": true,
                "autoHealEnabled": false,
                "azureStorageAccounts": {},
                "defaultDocuments": [
                    "Default.htm",
                    "Default.html",
                    "Default.asp",
                    "index.htm",
                    "index.html",
                    "iisstart.htm",
                    "default.aspx",
                    "index.php",
                    "hostingstart.html"
                ],
                "detailedErrorLoggingEnabled": false,
                "elasticWebAppScaleLimit": 0,
                "experiments": {
                    "rampUpRules": []
                },
                "ftpsState": "AllAllowed",
                "functionsRuntimeScaleMonitoringEnabled": false,
                "http20Enabled": false,
                "http20ProxyFlag": 0,
                "httpLoggingEnabled": false,
                "ipSecurityRestrictions": [
                    {
                        "action": "Allow",
                        "description": "Allow all access",
                        "ipAddress": "Any",
                        "name": "Allow all",
                        "priority": 2147483647
                    }
                ],
                "loadBalancing": "LeastRequests",
                "localMySqlEnabled": false,
                "logsDirectorySizeLimit": 35,
                "managedPipelineMode": "Integrated",
                "minTlsVersion": "1.0",
                "minimumElasticInstanceCount": 1,
                "netFrameworkVersion": "v6.0",
                "numberOfWorkers": 1,
                "preWarmedInstanceCount": 0,
                "publicNetworkAccess": "Enabled",
                "publishingUsername": "[concat('$', variables('siteNames')[copyIndex()])]",
                "remoteDebuggingEnabled": false,
                "requestTracingEnabled": false,
                "scmIpSecurityRestrictions": [
                    {
                        "action": "Allow",
                        "description": "Allow all access",
                        "ipAddress": "Any",
                        "name": "Allow all",
                        "priority": 2147483647
                    }
                ],
                "scmIpSecurityRestrictionsUseMain": false,
                "scmMinTlsVersion": "1.2",
                "scmType": "None",
                "use32BitWorkerProcess": false,
                "virtualApplications": [
                    {
                        "physicalPath": "site\\wwwroot",
                        "preloadEnabled": true,
                        "virtualPath": "/"
                    }
                ],
                "vnetPrivatePortsCount": 0,
                "vnetRouteAllEnabled": false,
                "webSocketsEnabled": true
            },
            "tags": "[variables('commonTags')]"
        },
        {
            "type": "Microsoft.Web/sites/hostNameBindings",
            "apiVersion": "2024-11-01",
            "name": "[concat(variables('siteNames')[copyIndex()], '/', variables('siteNames')[copyIndex()], '.azurewebsites.net')]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "hostNameBindingCopy",
                "count": "[length(variables('siteNames'))]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('siteNames')[copyIndex()])]"
            ],
            "properties": {
                "hostNameType": "Verified",
                "siteName": "[variables('siteNames')[copyIndex()]]"
            }
        },
        {
            "type": "Microsoft.Sql/servers/databases",
            "apiVersion": "2023-08-01",
            "name": "[concat(parameters('sqlServerName'), '/', variables('sqlDatabaseName'))]",
            "location": "[parameters('sqlDatabaseLocation')]",
            "sku": {
                "name": "S1",
                "tier": "Standard",
                "capacity": 20
            },
            "properties": {
                "collation": "SQL_Latin1_General_CP1_CI_AS",
                "maxSizeBytes": 268435456000,
                "zoneRedundant": false,
                "readScale": "Disabled",
                "requestedBackupStorageRedundancy": "Geo"
            },
            "tags": "[variables('commonTags')]"
        }
    ],
    "outputs": {
        "appServicePlanId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
        },
        "webAppUrls": {
            "type": "array",
            "copy": {
                "count": "[length(variables('siteNames'))]",
                "input": "[concat('https://', variables('siteNames')[copyIndex()], '.azurewebsites.net')]"
            }
        },
        "sqlDatabaseId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Sql/servers/databases', parameters('sqlServerName'), variables('sqlDatabaseName'))]"
        }
    }
}
